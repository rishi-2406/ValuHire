# Database & Redis (Use docker-compose names in production: postgres, redis)
DATABASE_URL="postgresql://valuhire:valuhire@localhost:5432/valuhire?schema=public"
# In production on VPS: "postgresql://valuhire:valuhire@postgres:5432/valuhire?schema=public"
REDIS_URL="redis://localhost:6379"
# In production on VPS: "redis://redis:6379"

JWT_ACCESS_SECRET="replace-with-access-secret"
JWT_REFRESH_SECRET="replace-with-refresh-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
ADMIN_EMAIL="admin@valuhire.local"
ADMIN_PASSWORD="ChangeMe123!"

# Update WEB_ORIGIN to your Vercel deployment URL (e.g. https://valuhire.vercel.app)
WEB_ORIGIN="http://localhost:5173"
API_PORT="4000"

# Must remain true on VPS to ensure Docker-in-Docker works securely
VALUHIRE_USE_DOCKER="true"
