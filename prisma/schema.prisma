generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum CompanyStatus {
  PENDING
  APPROVED
  BANNED
}

enum CampaignStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  ASSESSMENT_INVITED
  ASSESSMENT_COMPLETED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  REJECTED
  SHORTLISTED
  HIRED
}

enum AssessmentSessionStatus {
  STARTED
  SUBMITTED
  SCORED
  EXPIRED
}

enum SubmissionStatus {
  QUEUED
  RUNNING
  PASSED
  FAILED
  COMPILE_ERROR
  RUNTIME_ERROR
  TIMEOUT
}

enum InterviewStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

model User {
  id                String              @id @default(cuid())
  role              UserRole
  status            UserStatus          @default(ACTIVE)
  name              String
  email             String              @unique
  passwordHash      String
  resumeUrl         String?
  bio               String?
  skills            String[]            @default([])
  profilePicUrl     String?
  githubUrl         String?
  leetcodeUrl       String?
  codeforcesUrl     String?
  linkedinUrl       String?
  portfolioUrl      String?
  companyId         String?
  company           Company?            @relation(fields: [companyId], references: [id])
  applications      Application[]
  sessions          AssessmentSession[]
  submissions       Submission[]
  interviewSlots    InterviewSlot[]     @relation("CandidateInterviews")
  recruiterSlots    InterviewSlot[]     @relation("RecruiterInterviews")
  feedbackGiven     InterviewFeedback[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

model Company {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      CompanyStatus @default(PENDING)
  website     String?
  recruiters  User[]
  campaigns   Campaign[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Campaign {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  title          String
  description    String?
  targetRole     String?
  durationDays   Int?
  requiredSkills String[]       @default([])
  status         CampaignStatus @default(DRAFT)
  expiresAt      DateTime?
  interviewQuestions Json?
  assessment     Assessment?
  applications   Application[]
  inviteLinks    InviteLink[]
  interviewSlots InterviewSlot[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Application {
  id          String            @id @default(cuid())
  candidateId String
  candidate   User              @relation(fields: [candidateId], references: [id])
  campaignId  String
  campaign    Campaign          @relation(fields: [campaignId], references: [id])
  status      ApplicationStatus @default(APPLIED)
  appliedAt   DateTime          @default(now())

  @@unique([candidateId, campaignId])
}

model Assessment {
  id                  String              @id @default(cuid())
  campaignId          String              @unique
  campaign            Campaign            @relation(fields: [campaignId], references: [id])
  title               String
  instructions        String?
  durationMinutes     Int                 // Fallback total duration
  mcqDurationMinutes  Int?                // Independent MCQ timer
  codingDurationMinutes Int?              // Independent Coding timer
  mcqQuestions        McqQuestion[]
  codingQuestions     CodingQuestion[]
  sessions            AssessmentSession[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model McqQuestion {
  id           String      @id @default(cuid())
  assessmentId String
  assessment   Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  slotIndex    Int         @default(0) // Questions with the same slotIndex are variants
  prompt       String
  options      Json
  correctKey   String
  points       Int         @default(1)
  answers      McqAnswer[]
}

model CodingQuestion {
  id           String       @id @default(cuid())
  assessmentId String
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  slotIndex    Int          @default(0) // Questions with the same slotIndex are variants
  title        String
  statement    String
  difficulty   String
  language     String       @default("javascript") // Default language expected
  constraints  String?
  points       Int          @default(10)
  testCases    TestCase[]
  submissions  Submission[]
}

model TestCase {
  id               String         @id @default(cuid())
  codingQuestionId String
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
  input            String
  expectedOutput   String
  isHidden         Boolean        @default(false)
}

model AssessmentSession {
  id           String                  @id @default(cuid())
  assessmentId String
  assessment   Assessment              @relation(fields: [assessmentId], references: [id])
  candidateId  String
  candidate    User                    @relation(fields: [candidateId], references: [id])
  status       AssessmentSessionStatus @default(STARTED)
  startedAt    DateTime                @default(now())
  submittedAt  DateTime?
  expiresAt    DateTime
  selectedVariants Json?
  mcqAnswers   McqAnswer[]
  submissions  Submission[]
  result       AssessmentResult?
  proctorEvents ProctorEvent[]
}

model McqAnswer {
  id                 String            @id @default(cuid())
  assessmentSessionId String
  session            AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  questionId         String
  question           McqQuestion       @relation(fields: [questionId], references: [id])
  selectedKey        String
  isCorrect          Boolean
  pointsAwarded      Int

  @@unique([assessmentSessionId, questionId])
}

model Submission {
  id                  String            @id @default(cuid())
  assessmentSessionId String?
  session             AssessmentSession? @relation(fields: [assessmentSessionId], references: [id])
  candidateId         String
  candidate           User              @relation(fields: [candidateId], references: [id])
  codingQuestionId    String
  codingQuestion      CodingQuestion    @relation(fields: [codingQuestionId], references: [id])
  code                String
  language            String
  status              SubmissionStatus  @default(QUEUED)
  score               Int               @default(0)
  executionTimeMs     Int?
  testResults         Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model AssessmentResult {
  id                    String            @id @default(cuid())
  assessmentSessionId   String            @unique
  session               AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  candidateId           String
  assessmentId          String
  mcqScore              Int               @default(0)
  codingScore           Int               @default(0)
  totalScore            Int               @default(0)
  durationSeconds       Int               @default(0)
  mcqDurationSeconds    Int?
  codingDurationSeconds Int?
  rank                  Int?
  totalApplicants       Int?
  testCasesPassed       Int?
  testCasesTotal        Int?
  createdAt             DateTime          @default(now())
}

model ProctorEvent {
  id                  String            @id @default(cuid())
  assessmentSessionId String
  session             AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  type                String
  metadata            Json?
  occurredAt          DateTime          @default(now())
}

model InviteLink {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
}

model InterviewSlot {
  id          String              @id @default(cuid())
  campaignId  String
  campaign    Campaign            @relation(fields: [campaignId], references: [id])
  recruiterId String
  recruiter   User                @relation("RecruiterInterviews", fields: [recruiterId], references: [id])
  candidateId String
  candidate   User                @relation("CandidateInterviews", fields: [candidateId], references: [id])
  status      InterviewStatus     @default(SCHEDULED)
  startsAt    DateTime
  endsAt      DateTime
  roomCode    String              @unique
  feedback    InterviewFeedback?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model InterviewFeedback {
  id              String        @id @default(cuid())
  interviewSlotId String        @unique
  interviewSlot   InterviewSlot @relation(fields: [interviewSlotId], references: [id], onDelete: Cascade)
  interviewerId   String
  interviewer     User          @relation(fields: [interviewerId], references: [id])
  notes           String?
  rating          Int?
  recommendation  String?
  createdAt       DateTime      @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
